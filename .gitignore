# =====================================================================
# GreenAmal — git ignore
# =====================================================================

# ---------------------------------------------------------------------
# macOS / Windows / Linux file-system noise
# ---------------------------------------------------------------------
.DS_Store
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?
__MACOSX
Thumbs.db
Desktop.ini
*~

# ---------------------------------------------------------------------
# Editors / IDEs
# ---------------------------------------------------------------------
.vscode/
.idea/
.fleet/
.zed/
.history/
*.code-workspace
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ---------------------------------------------------------------------
# Local environment & secrets — NEVER commit these
# ---------------------------------------------------------------------
includes/config.local.php
db-test.php
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
*.cer
*.der
*.p12
*.pfx
*.ppk
*_rsa
*_rsa.pub
*_ed25519
*_ed25519.pub
auth.json
credentials.json

# ---------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------
/vendor/
/node_modules/

# ---------------------------------------------------------------------
# Runtime / logs / temp
# ---------------------------------------------------------------------
*.log
*.pid
*.lock
debug.log
error_log
storage/logs/
/tmp/
/cache/

# cPanel sometimes drops a default cgi-bin into web roots
cgi-bin/

# ---------------------------------------------------------------------
# User-uploaded media — too heavy to version, lives only on the server
# ---------------------------------------------------------------------
/assets/img/uploads/products/
/assets/img/uploads/categories/
/assets/img/uploads/hero/
/assets/img/uploads/posts/

# ---------------------------------------------------------------------
# Backups (local dumps, WP migrations, archive files dropped into the tree)
# ---------------------------------------------------------------------
/backups/
/wordpress-backup/
/wordpress-backups/
*.sql.bak
*.dump
*.bak
*.old
*.orig
*.tar
*.tar.gz
*.tgz
*.zip
*.rar
*.7z

# Legacy HTML mock-ups kept on disk for reference — not part of the running app
/_maquette-html-backup/

# ---------------------------------------------------------------------
# Build & CI artefacts
# ---------------------------------------------------------------------
/dist/
/build/
.phpunit.result.cache
coverage/

# ---------------------------------------------------------------------
# Internal planning docs (kept on disk, off the repo)
# ---------------------------------------------------------------------
avancement.md
DASHBOARD-TODO.md
HOSTING-DEPLOY.md
ROADMAP.md
SEO-AUDIT.md
SETUP.md
TODO.md
